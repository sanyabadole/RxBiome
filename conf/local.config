/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Local development config — laptop-friendly caps

    Base labels (e.g. process_medium → 36 GB) exceed many laptops. resourceLimits clamps
    requests so -profile local still schedules (same idea as conf/test.config).

    Override on the CLI if you have more headroom, e.g. --max_memory 32.GB --max_cpus 8
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    max_cpus   = 4
    max_memory = '15.GB'
    max_time   = '24.h'
}

process {
    resourceLimits = [
        cpus: params.max_cpus as int,
        memory: params.max_memory,
        time: params.max_time
    ]
}
