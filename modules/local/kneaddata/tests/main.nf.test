nextflow_process {

    name "Test Process KNEADDATA"
    script "../main.nf"
    process "KNEADDATA"

    tag "modules"
    tag "modules_local"
    tag "kneaddata"

    test("kneaddata - stub - fastq") {

        options "-stub-run"

        when {
            process {
                """
                ch_bt2 = Channel.fromPath("${projectDir}/tests/data/dummy_kneaddata_host_db/hg37dec_v0.1*.bt2", checkIfExists: true).collect()
                input[0] = Channel.of([
                    [ id: 'test', single_end: false ],
                    [
                        file("${projectDir}/tests/data/test_R1.fastq.gz", checkIfExists: true),
                        file("${projectDir}/tests/data/test_R2.fastq.gz", checkIfExists: true)
                    ]
                ]).combine(ch_bt2).map { row ->
                    def L = row instanceof List ? row : [row]
                    tuple(L[0], L[1], L.subList(2, L.size()))
                }
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.reads.size() == 1 },
                { assert process.out.log.size() == 1 },
                { assert process.out.reads[0][1][0].size() > 0 },
                { assert process.out.reads[0][1][1].size() > 0 }
            )
        }
    }
}

